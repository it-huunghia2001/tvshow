generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model settings {
  id            Int      @id @default(autoincrement())
  branch_id     String   @unique
  customer_name String   @default("Chào mừng quý khách")
  image_url     String   @default("https://images.unsplash.com/photo-1503376780353-7e6692767b70?q=80&w=1200")
  updated_at    DateTime @default(now()) @updatedAt
}
